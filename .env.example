# Copy to .env and adjust. Never commit real secrets.
# Vite exposes only variables prefixed with VITE_ to client code.

# App (slug / identifier; optional — use in code via import.meta.env.VITE_APP_NAME)
VITE_APP_NAME=termo

# Mirrors typical deploy target; Vite already provides import.meta.env.MODE
VITE_ENV=development

# Public base path for production (e.g. GitHub Pages project site). Must end with /
VITE_BASE_PATH=/Termo/

# Firebase (optional — fill if you add Firebase later)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
